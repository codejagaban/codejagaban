---
interface Props {
  size?: "sm" | "md" | "lg";
}

const { size = "md" } = Astro.props;
---

<div class:list={["social-links", `size-${size}`]}>
  <a
    href="http://github.com/codejagaban"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="GitHub"
    class="social-link link-underline"
  >
    Github
  </a>

  <a
    href="http://x.com/codejagaban"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="X (Twitter)"
    class="social-link link-underline"
  >
    Twitter
  </a>

  <a
    href="https://www.linkedin.com/in/codejagaban/"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="LinkedIn"
    class="social-link link-underline"
  >
    LinkedIn
  </a>

  <a
    href="mailto:hellotsjamin@gmail.com"
    aria-label="Email"
    class="social-link link-underline"
  >
    Email
  </a>
</div>

<style>
  .social-links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-flex;
    font-size: var(--text-sm);
    text-transform: lowercase;
    font-family: var(--font-sans);
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    transition: color var(--transition-base);
    padding-bottom: 2px;
  }

  .social-link:hover {
    color: var(--color-text);
  }

  .social-link:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* Override the built-in global .link-underline to be persistent */
  .social-link.link-underline::after {
    transform: scaleX(1);
    background-color: var(--color-border-hover);
    height: 1px;
    bottom: 0px;
    transition:
      background-color var(--transition-base),
      transform var(--transition-base);
  }

  .social-link.link-underline:hover::after {
    background-color: var(--color-text);
  }

  /* Size variants */
  .size-sm .social-link {
    font-size: var(--text-xs);
  }

  .size-md .social-link {
    font-size: var(--text-sm);
  }

  .size-lg .social-link {
    font-size: var(--text-base);
  }
</style>
