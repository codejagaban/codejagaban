---
import Layout from "../layouts/Layout.astro";
import data from "../data/talks.json";
import AnimatedShow from "../components/AnimatedShow";
---

<Layout
  title="Talks, Conferences and events Trust Jamin has spoken at"
  description="Explore talks and events crafted by Trust Jamin"
  keywords="Trust Jamin talks, speaking opportunities, conferences, DevRel, TypeScript, Node.js"
  image="/talks.png"
>
  <section class="talks">
    <div class="container">
      <AnimatedShow client:load>
        <div class="talks-header">
          <h1>Speaking.</h1>
          <p class="intro">
            I speak at conferences and meetups about developer experience,
            technical writing, and web technologies. Here are some of my recent
            talks.
          </p>
        </div>
      </AnimatedShow>

      <AnimatedShow client:load stagger className="talks-list">
        {
          data.map((talk) => (
            <div class="talk-row">
              <h2 class="talk-title">{talk.title}</h2>

              <div class="talk-meta">
                <span class="date-text">{talk.date}</span>
                <a
                  href={talk.confLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="conference-link"
                >
                  {talk.confName}
                  <svg
                    width="10"
                    height="10"
                    viewBox="0 0 12 12"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M2.07102 11.3494L0.963068 10.2415L9.2017 1.98864H2.83807L2.85227 0.454545H11.8438V9.46023H10.2955L10.3097 3.09659L2.07102 11.3494Z"
                      fill="currentColor"
                    />
                  </svg>
                </a>
                {talk.slide && (
                  <a
                    href={talk.slide}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="slide-link"
                  >
                    Slides
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </AnimatedShow>

      <AnimatedShow client:load delay={0.4}>
        <div class="invite-section">
          <h2>Want me to speak at your event?</h2>
          <p>I'd love to share my experiences with your community.</p>
          <a href="mailto:hellotsjamin@gmail.com" class="invite-cta">
            Get in touch
          </a>
        </div>
      </AnimatedShow>
    </div>
  </section>
</Layout>

<style>
  .talks {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .talks-header {
    margin-bottom: var(--space-3xl);
  }

  .talks-header h1 {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-md);
  }

  .intro {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0;
  }

  .talks-list {
    display: flex;
    flex-direction: column;
  }

  .talk-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    transition: all var(--transition-base);
  }

  .talk-row:hover {
    padding-left: var(--space-md);
    padding-right: var(--space-md);
    border-bottom-color: var(--color-text);
    background-color: var(--color-bg-elevated);
  }

  .talk-title {
    font-size: var(--text-3xl);
    margin: 0;
    line-height: 1.2;
    flex: 1;
    color: var(--color-text);
  }

  .talk-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-xs);
    min-width: 200px;
    text-align: right;
  }

  .date-text {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .conference-link {
    font-size: var(--text-base);
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    transition: color var(--transition-fast);
  }

  .conference-link:hover {
    color: var(--color-text-muted);
  }

  .slide-link {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-top: var(--space-xs);
  }

  .slide-link:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  .invite-section {
    margin-top: var(--space-3xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border);
  }

  .invite-section h2 {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-sm);
  }

  .invite-section p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .invite-cta {
    display: inline-flex;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 4px;
    transition:
      color var(--transition-base),
      border-color var(--transition-base);
  }

  .invite-cta:hover {
    color: var(--color-text-muted);
    border-color: transparent;
  }

  @media (max-width: 768px) {
    .talk-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
      padding: var(--space-md) 0;
    }

    .talk-meta {
      align-items: flex-start;
      text-align: left;
    }

    .talk-title {
      font-size: var(--text-2xl);
    }
  }
</style>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Talks, Conferences and events Trust Jamin has spoken at",
    "description": "Explore talks and events crafted by Trust Jamin",
    "url": "https://jamin.sh/talks",
    "author": {
      "@type": "Person",
      "name": "Trust Jamin",
      "url": "https://jamin.sh"
    }
  }
</script>
