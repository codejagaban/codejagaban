---
import Layout from "../layouts/Layout.astro";
import projects from "../data/projects.json";
import AnimatedShow from "../components/AnimatedShow";
---

<Layout
  title="Projects by Trust Jamin"
  description="Explore project and community initiatives handled by Trust Jamin"
  keywords="Trust Jamin projects, web development, TypeScript, Next.js, Gatsby, software engineering"
  image="/projects.png"
>
  <section class="projects">
    <div class="container">
      <AnimatedShow client:load>
        <div class="projects-header">
          <h1>Projects.</h1>
          <p class="intro">
            A collection of projects I've built and contributed to over the
            years. From personal experiments to production applications.
          </p>
        </div>
      </AnimatedShow>

      <div class="projects-content">
        {
          projects.map((section, i) => (
            <AnimatedShow client:load delay={i * 0.1}>
              <div
                class="project-section"
                id={section.section.replace(/\s+/g, "-").toLowerCase()}
              >
                <div class="section-header">
                  <h2>{section.section}</h2>
                  <span class="project-count">
                    {section.projects.length} projects
                  </span>
                </div>

                <div class="projects-grid">
                  {section.projects.map((project) => (
                    <a
                      href={project.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-card"
                    >
                      <div class="project-header">
                        <h3 class="project-name">{project.name}</h3>
                        <svg
                          class="arrow-icon"
                          width="20"
                          height="20"
                          viewBox="0 0 20 20"
                          fill="none"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <path
                            d="M5 15L15 5M15 5H8M15 5V12"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </div>

                      <p class="project-description">{project.description}</p>

                      <div class="tech-stack">
                        {project.technologies
                          .slice(0, 5)
                          .map((tech: string) => (
                            <span class="tech-tag">{tech}</span>
                          ))}
                        {project.technologies.length > 5 && (
                          <span class="tech-tag">
                            +{project.technologies.length - 5}
                          </span>
                        )}
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </AnimatedShow>
          ))
        }
      </div>

      <AnimatedShow client:load delay={0.2}>
        <div class="github-cta">
          <p>Want to see more of my code?</p>
          <a
            href="https://github.com/codejagaban"
            target="_blank"
            rel="noopener noreferrer"
            class="link-underline"
          >
            Visit my GitHub profile
          </a>
        </div>
      </AnimatedShow>
    </div>
  </section>
</Layout>

<style>
  .projects {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .projects-header {
    margin-bottom: var(--space-3xl);
  }

  .projects-header h1 {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-md);
  }

  .intro {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0;
  }

  /* Project Sections */
  .project-section {
    margin-bottom: var(--space-3xl);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-text);
  }

  .section-header h2 {
    font-size: var(--text-2xl);
    margin: 0;
  }

  .project-count {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg) 0;
    transition: all var(--transition-base);
    border-top: 1px solid transparent;
    text-decoration: none;
  }

  .project-card:hover {
    padding-left: var(--space-md);
    border-left: 2px solid var(--color-text);
  }

  .project-card:hover .project-name {
    color: var(--color-text);
  }

  .project-card:hover .arrow-icon {
    transform: translate(3px, -3px);
    color: var(--color-text);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-md);
  }

  .project-name {
    font-size: var(--text-xl);
    font-weight: 400;
    margin: 0;
    color: var(--color-text);
    transition: color var(--transition-base);
  }

  .arrow-icon {
    flex-shrink: 0;
    color: var(--color-text-subtle);
    transition:
      transform var(--transition-base),
      color var(--transition-base);
  }

  .project-description {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.6;
    flex-grow: 1;
    margin: 0 0 var(--space-lg);
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: auto;
  }

  .tech-tag {
    font-size: var(--text-xs);
    font-family: var(--font-sans);
    letter-spacing: 0.05em;
    color: var(--color-text-subtle);
    text-transform: uppercase;
  }

  .tech-tag:not(:last-child)::after {
    content: "•";
    margin-left: var(--space-xs);
    color: var(--color-border-hover);
  }

  /* GitHub CTA */
  .github-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-top: var(--space-3xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border);
  }

  .github-cta p {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    margin: 0 0 var(--space-sm);
  }

  .github-link {
    font-size: var(--text-base);
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
