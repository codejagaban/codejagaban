---
import Layout from "../layouts/Layout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import AnimatedShow from "../components/AnimatedShow";
---

<Layout
  title="Trust Jamin Okpukoro – Senior Technical Writer & Developer Advocate"
  description="Trust Jamin Okpukoro is a senior software engineer, technical writer, and developer advocate focused on building developer-first content, tools, and communities."
  keywords="developer advocate, technical writer, DevRel, Trust Jamin, Trust Okpukoro, open source, API documentation, developer communities"
  image="/image.png"
>
  <section class="hero">
    <div class="container">
      <AnimatedShow client:load stagger>
        <!-- The framer-motion stagger will automatically animate the direct children -->
        <div>
          <p class="greeting">Hello, I'm</p>
        </div>

        <div>
          <h1 class="name">Trust Jamin.</h1>
        </div>

        <div>
          <p class="role">Software Engineer & Developer Advocate</p>
        </div>

        <div>
          <div class="intro">
            <p>
              Bridging the gap between <i>developers</i> and <i>technology</i>.
              I build <a href="/projects" class="link-underline">solutions</a>,
              write
              <a href="/blog" class="link-underline">documentation</a>, and
              contribute to
              <a
                href="http://github.com/codejagaban"
                target="_blank"
                rel="noopener noreferrer"
                class="link-underline">open-source</a
              > projects.
            </p>
            <p>
              Currently, I'm exploring <i>Agentic engineering</i> and developing intelligent
              <i>AI workflows</i>.
            </p>
          </div>
        </div>

        <div>
          <div class="actions">
            <a href="/about" class="about-link">
              More about me
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M6 12L10 8L6 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </a>
            <div class="socials">
              <SocialLinks size="md" />
            </div>
          </div>
        </div>
      </AnimatedShow>
    </div>
  </section>
</Layout>

<style>
  .hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding-top: var(--space-lg);
  }

  .greeting {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-sm);
  }

  .name {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-xs);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .role {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    font-weight: 300;
    margin-bottom: var(--space-xl);
  }

  .intro {
    max-width: 700px;
    margin-bottom: var(--space-2xl);
  }

  .intro p {
    font-size: var(--text-2xl);
    line-height: 1.4;
    color: var(--color-text);
  }

  .intro i {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
  }

  .intro a {
    color: var(--color-text);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
    margin-top: var(--space-2xl);
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .about-link:hover {
    color: var(--color-text);
  }

  .about-link svg {
    transition: transform var(--transition-base);
  }

  .about-link:hover svg {
    transform: translateX(4px);
  }

  .socials {
    opacity: 0.5;
    transition: opacity var(--transition-base);
  }

  .socials:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .intro p {
      font-size: var(--text-xl);
    }

    .actions {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-lg);
    }
  }
</style>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Trust Jamin",
    "url": "https://www.jamin.sh",
    "jobTitle": "Technical Writer and Developer Advocate",
    "sameAs": [
      "https://www.linkedin.com/in/codejagaban",
      "https://github.com/codejagaban",
      "https://dev.to/codejagaban",
      "https://twitter.com/codejagaban",
      "https://blog.jamin.sh"
    ],
    "description": "Trust Jamin is a senior software engineer, technical writer, and developer advocate focused on building developer-first content, tools, and communities."
  }
</script>
