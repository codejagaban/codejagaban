---
import Layout from "../layouts/Layout.astro";
import AnimatedShow from "../components/AnimatedShow";
---

<Layout
  title="About Trust Jamin Okpukoro"
  description="Learn about Trust Jamin Okpukoro's projects, technical articles, community management endeavors, involvements in open source projects and pieces of information about him."
  keywords="Trust Jamin, Trust Okpukoro, Trust Jamin Okpukoro, developer advocate, open source, technical Writing, community engagement, DevRel"
  image="/about.png"
>
  <section class="about">
    <div class="container">
      <AnimatedShow client:load>
        <div class="about-header">
          <h1>About me.</h1>
          <p class="lead">
            Hey 👋🏼, I'm Trust Jamin — a software engineer with years of
            experience building products that run on the web.
          </p>
        </div>
      </AnimatedShow>

      <div class="about-content">
        <AnimatedShow client:load delay={0.1}>
          <div class="about-story">
            <p>
              Lately, you'll find me either writing a tutorial or documentation
              (sometimes it's about a bug/fix I encountered) that can help
              developers use modern tools to build cool applications 🙌🏼
            </p>
            <p>
              I believe constant learning and improvement are the catalysts of
              personal and professional growth, and they can empower an
              individual to adapt to change, overcome challenges, and unlock
              their full potential — so I'm always learning to become the finest
              version of myself.
            </p>
            <p class="cta">
              <a href="mailto:hellotsjamin@gmail.com" class="link-underline">
                Shoot me an email
              </a>
            </p>
          </div>
        </AnimatedShow>

        <AnimatedShow client:load stagger delay={0.2}>
          <div class="section">
            <h2>Skills & Tech</h2>
            <div class="skills-grid">
              <div class="skill-category">
                <h3>Development</h3>
                <p>
                  Node.js, Next.js, React.js, Astro, TypeScript, JavaScript,
                  GoLang, GraphQL
                </p>
              </div>
              <div class="skill-category">
                <h3>Infrastructure</h3>
                <p>Docker, AWS, PostgreSQL, MySQL, MongoDB</p>
              </div>
              <div class="skill-category">
                <h3>DevRel & Writing</h3>
                <p>
                  Technical Writing, API Documentation, Community Building,
                  Content Strategy
                </p>
              </div>
            </div>
          </div>
        </AnimatedShow>

        <AnimatedShow client:load stagger delay={0.2}>
          <div class="section">
            <h2>Writing Activities</h2>
            <div class="platform-list">
              <a
                href="https://uploadcare.com/blog/author/trust-jamin/"
                target="_blank"
                rel="noopener noreferrer"
                class="platform-link"
              >
                <span class="platform-name">Uploadcare</span>
                <span class="platform-desc">Developer tutorials & guides</span>
              </a>
              <a
                href="https://docs.directus.io/blog/"
                target="_blank"
                rel="noopener noreferrer"
                class="platform-link"
              >
                <span class="platform-name">Directus</span>
                <span class="platform-desc">CMS integrations & tutorials</span>
              </a>
              <a
                href="https://blog.apify.com/author/jamin/"
                target="_blank"
                rel="noopener noreferrer"
                class="platform-link"
              >
                <span class="platform-name">Apify</span>
                <span class="platform-desc">Web scraping & automation</span>
              </a>
              <a
                href="https://blog.jamin.sh/"
                target="_blank"
                rel="noopener noreferrer"
                class="platform-link"
              >
                <span class="platform-name">Personal Blog</span>
                <span class="platform-desc">General tech insights</span>
              </a>
              <a
                href="https://dev.to/codejagaban"
                target="_blank"
                rel="noopener noreferrer"
                class="platform-link"
              >
                <span class="platform-name">Dev.to</span>
                <span class="platform-desc">Community articles</span>
              </a>
              <a
                href="https://blog.openreplay.com/authors/trust-jamin"
                target="_blank"
                rel="noopener noreferrer"
                class="platform-link"
              >
                <span class="platform-name">OpenReplay</span>
                <span class="platform-desc">Frontend development</span>
              </a>
            </div>
          </div>
        </AnimatedShow>

        <AnimatedShow client:load stagger delay={0.2}>
          <div class="section">
            <h2>Community</h2>
            <div class="community-list">
              <div class="community-item">
                <span class="community-role">Co-founder</span>
                <span>Community Leads Africa</span>
              </div>
              <div class="community-item">
                <span class="community-role">DevRel Community Lead</span>
                <span>Polygon Guild Lagos</span>
              </div>
              <div class="community-item">
                <span class="community-role">Community Manager</span>
                <span>Notion Lagos</span>
              </div>
              <div class="community-item">
                <span class="community-role">Champion</span>
                <span>Twilio</span>
              </div>
              <div class="community-item">
                <span class="community-role">Organizer</span>
                <span>GDG Sapele</span>
              </div>
            </div>
          </div>
        </AnimatedShow>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .about-header {
    margin-bottom: var(--space-3xl);
  }

  .about-header h1 {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-md);
  }

  .lead {
    font-size: var(--text-2xl);
    color: var(--color-text);
    line-height: 1.4;
    max-width: 800px;
  }

  .about-story p {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text-muted);
    max-width: 650px;
  }

  .cta {
    margin-top: var(--space-xl);
  }

  .cta a {
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 400;
  }

  .section {
    margin-top: var(--space-3xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border);
  }

  .section h2 {
    font-size: var(--text-3xl);
    margin-top: 0;
    margin-bottom: var(--space-xl);
  }

  /* Skills */
  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .skill-category h3 {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-xs);
    text-transform: uppercase;
    font-family: var(--font-sans);
    letter-spacing: 0.1em;
  }

  .skill-category p {
    font-size: var(--text-lg);
    color: var(--color-text);
    margin: 0;
  }

  /* Platforms */
  .platform-list {
    display: flex;
    flex-direction: column;
  }

  .platform-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .platform-link:hover {
    padding-left: var(--space-sm);
    padding-right: var(--space-sm);
    border-color: var(--color-text);
  }

  .platform-name {
    font-size: var(--text-xl);
    color: var(--color-text);
    font-weight: 400;
  }

  .platform-desc {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-sans);
  }

  /* Community */
  .community-list {
    display: flex;
    flex-direction: column;
  }

  .community-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-xl);
  }

  .community-role {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .platform-link,
    .community-item {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Trust Jamin Okpukoro",
    "url": "https://jamin.sh",
    "jobTitle": "Senior Technical Writer and Developer Advocate",
    "description": "Senior software engineer, technical writer, and developer advocate focused on building developer-first content, tools, and communities.",
    "sameAs": [
      "https://www.linkedin.com/in/codejagaban",
      "https://github.com/codejagaban",
      "https://dev.to/codejagaban",
      "https://twitter.com/codejagaban"
    ]
  }
</script>
